# Broker credentials — copy to .env and fill in real values. Never commit .env.
# Priority: Dhan (if set) → Shoonya → MockBroker

# Dhan (DhanHQ)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Shoonya (Finvasia)
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_TOTP_SECRET=

SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=
SHOONYA_IMEI=

# AI Research Bot — set ONE of the following (priority: Groq > OpenRouter > Ollama)
# Groq: free tier, fast — https://console.groq.com (model: llama-3.3-70b-versatile)
GROQ_API_KEY=
# OpenRouter: free Qwen/DeepSeek models — https://openrouter.ai (model: qwen/qwen-2.5-72b-instruct:free)
OPENROUTER_API_KEY=
# Ollama: fully local, no key needed — set URL if running locally
OLLAMA_BASE_URL=http://localhost:11434
